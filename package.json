{
  "name": "web-geometry-pose",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @lumetriq/geometry-core && npm run build -w @lumetriq/geometry-client",
    "build:pages": "npm run build -w @lumetriq/geometry-core",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
